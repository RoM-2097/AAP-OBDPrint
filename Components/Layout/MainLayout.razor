@inherits LayoutComponentBase

<div class="page-wrapper">
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    /* Clean full-width template layout configuration */
    .page-wrapper {
        display: block;
        width: 100%;
        min-height: 100vh;
        margin: 0;
        padding: 0;
    }

    main {
        width: 100%;
    }

    /* Remaps default app.css styles that might squeeze the main canvas */
    .sidebar, .top-row, nav {
        display: none !important;
    }
</style>